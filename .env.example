# === Telegram ===
# Токен бота, полученный у @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# ID канала для РФ-вакансий (формат: -100xxxxxxxxxx)
TELEGRAM_CHANNEL_RU=-100123456789

# ID канала для глобальных вакансий (формат: -100xxxxxxxxxx)
TELEGRAM_CHANNEL_GLOBAL=-100987654321

# === hh.ru ===
# hh.ru не требует токен для базового поиска, но лимиты без него жёстче
# Зарегистрировать приложение: https://dev.hh.ru/
HH_USER_AGENT=VacancyParser/0.1 (your@email.com)

# === Планировщик ===
# Интервал парсинга в минутах
PARSE_INTERVAL_MINUTES=30

# === База данных ===
# Путь к файлу SQLite (относительно корня проекта)
DATABASE_PATH=data/vacancies.db

# === Логирование ===
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
