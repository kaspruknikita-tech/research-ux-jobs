# === Telegram ===
# Токен бота, полученный у @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# ID канала для РФ-вакансий (формат: -100xxxxxxxxxx)
TELEGRAM_CHANNEL_RU=-100123456789

# ID канала для глобальных вакансий (формат: -100xxxxxxxxxx)
TELEGRAM_CHANNEL_GLOBAL=-100987654321

# ID приватной группы модерации (формат: -100xxxxxxxxxx)
# Как получить: добавь бота в группу, напиши /id, бот ответит chat_id
TELEGRAM_MODERATION_CHAT=-100000000000

# === Telethon (парсер Telegram-каналов) ===
# Получить api_id и api_hash: https://my.telegram.org → API development tools
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here
# Строка сессии — получается запуском: python gen_tg_session.py
TG_SESSION_STRING=
# Каналы-источники вакансий через запятую
TG_SOURCE_CHANNELS=@researchjobs,@uxjobs
# За сколько дней брать сообщения
TG_DAYS_BACK=7

# === hh.ru ===
# hh.ru не требует токен для базового поиска, но лимиты без него жёстче
# Зарегистрировать приложение: https://dev.hh.ru/
HH_USER_AGENT=VacancyParser/0.1 (your@email.com)

# === Планировщик ===
# Интервал парсинга в минутах
PARSE_INTERVAL_MINUTES=30

# === База данных ===
# PostgreSQL URL (Railway выдаёт автоматически в переменной DATABASE_URL)
# Формат: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/vacancies

# === Hirify (опционально — для показа названий компаний) ===
# Требует Hirify Plus подписку
HIRIFY_EMAIL=your@email.com
HIRIFY_PASSWORD=your-password

# === OpenRouter (скоринг вакансий) ===
# Получить: https://openrouter.ai → Keys → Create Key
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# === Мониторинг балансов ===
# Railway API токен: Railway Dashboard → Account Settings → Tokens → Create Token
RAILWAY_API_TOKEN=your-railway-api-token-here
# Пороги остатка в USD — алерт шлётся если баланс ниже
RAILWAY_BALANCE_THRESHOLD=2.0
OPENROUTER_BALANCE_THRESHOLD=2.0
# Интервал проверки баланса в минутах
BALANCE_CHECK_INTERVAL_MINUTES=60
# Час (МСК) ежедневной сводки парсеров за прошедший день
DAILY_REPORT_HOUR=9

# === Логирование ===
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
